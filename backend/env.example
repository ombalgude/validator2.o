# Database
MONGODB_URL=mongodb://localhost:27017/authenticity-validator
MONGODB_TEST_URI=mongodb://localhost:27017/authenticity-validator-test
# Legacy alias also supported by the app: MONGODB_URI
# Atlas example:
# MONGODB_URL=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/authenticity-validator?retryWrites=true&w=majority

# JWT
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRE=7d

# Server
PORT=5000
NODE_ENV=development

# AI Services
AI_SERVICE_URL=http://localhost:8001

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# CORS
# Supports a single origin or a comma-separated allow-list.
FRONTEND_URL=http://localhost:3000,http://localhost

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100


# Blockchain
RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID
PRIVATE_KEY=your_private_key_here
CONTRACT_ADDRESS=your_contract_address_here
